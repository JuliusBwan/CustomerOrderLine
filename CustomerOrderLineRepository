/**
 * CustomerOrderLineRepositoryTest
 * --------------------------------
 * PURPOSE: Tests that the repository correctly returns a map of
 * CustomerOrderLine__c records keyed by their OrderItem Id,
 * and that null Ids in the input set are safely ignored.
 *
 * CHANGES FROM ORIGINAL:
 * - No changes needed. This test was already correct.
 */
@IsTest
private with sharing class CustomerOrderLineRepositoryTest {

    @IsTest
    static void testGetByOrderItemIds_returnsMapKeyedByOrderItem() {
        CustomerOrderLineTestDataFactory.OrderBundle b = CustomerOrderLineTestDataFactory.createOrderWithItem();
        CustomerOrderLine__c col = CustomerOrderLineTestDataFactory.createColLinkedTo(b.orderItem, 'Repo Test');

        Map<Id, CustomerOrderLine__c> byOi = CustomerOrderLineRepository.getByOrderItemIds(new Set<Id>{ b.orderItem.Id, null });

        Assert.areEqual(1, byOi.size(), 'Should return exactly one mapping');
        Assert.areEqual(col.Id, byOi.get(b.orderItem.Id).Id, 'Mapping should point to the created COL');
    }
}
