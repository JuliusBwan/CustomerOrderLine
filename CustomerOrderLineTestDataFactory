/**
 * CustomerOrderLineTestDataFactory
 * ---------------------------------
 * PURPOSE: A shared test helper that creates realistic Salesforce records
 * (Account, Product, Pricebook, Order, OrderItem) so that other test classes
 * don't have to repeat this setup code. Every test that needs an OrderItem
 * just calls createOrderWithItem() and gets a fully linked set of records back.
 *
 * OrderBundle:
 *   A simple container that holds all the created records together so the
 *   test can access any of them (e.g. b.orderItem, b.account, etc.)
 *
 * CHANGES FROM ORIGINAL:
 *
 * 1. Missing Product2 insert — NullPointerException before any test could run
 *    =========================================================================
 *    The original code declared:
 *        public Product2 product;
 *    inside OrderBundle, but createOrderWithItem() never actually created or
 *    inserted a Product2 record. It jumped straight to:
 *        b.pbe = new PricebookEntry(... Product2Id = b.product.Id ...);
 *
 *    Because b.product was null (never assigned), calling b.product.Id threw a
 *    NullPointerException before a single record could be inserted. Every test
 *    that used this factory would crash immediately.
 *
 *    The fix: insert a Product2 record before the PricebookEntry line, and
 *    assign it to b.product so the rest of the factory can use it correctly.
 */
@IsTest
public with sharing class CustomerOrderLineTestDataFactory {
    
    public class OrderBundle {
        public Account         account;
        public Product2        product;
        public Pricebook2      pricebook;
        public PricebookEntry  pbe;
        public Order           orderRec;
        public OrderItem       orderItem;
    }

    public static OrderBundle createOrderWithItem() {
        OrderBundle b = new OrderBundle();

        b.account = new Account(Name = 'Test Account');
        insert b.account;

        // FIXED: Product2 was never created in the original code.
        // b.product was null, so b.product.Id on the PricebookEntry line threw a NullPointerException.
        // We now create and insert the Product2 first, then use its Id below.
        b.product = new Product2(Name = 'Test Product', IsActive = true);
        insert b.product;

        Id stdPbId    = Test.getStandardPricebookId();
        b.pricebook   = [SELECT Id, IsActive FROM Pricebook2 WHERE Id = :stdPbId LIMIT 1];
        if (!b.pricebook.IsActive) { b.pricebook.IsActive = true; update b.pricebook; }

        b.pbe = new PricebookEntry(Pricebook2Id = stdPbId, Product2Id = b.product.Id, UnitPrice = 100, IsActive = true);
        insert b.pbe;

        b.orderRec = new Order(AccountId = b.account.Id, EffectiveDate = Date.today(), Status = 'Draft', Pricebook2Id = stdPbId);
        insert b.orderRec;

        b.orderItem = new OrderItem(OrderId = b.orderRec.Id, PricebookEntryId = b.pbe.Id, Quantity = 2, UnitPrice = 100);
        insert b.orderItem;

        return b;
    }

    public static CustomerOrderLine__c createColLinkedTo(OrderItem oi, String nameOpt) {
        CustomerOrderLine__c col = new CustomerOrderLine__c();
        col.Name         = (nameOpt == null) ? 'Existing COL' : nameOpt;
        col.OrderItem__c = oi.Id;
        insert col;
        return col;
    }
}
