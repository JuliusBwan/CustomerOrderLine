@IsTest
private class OrderItemTriggerTest {

    /*
     * ============================================================================
     * OrderItemTriggerTest
     * ============================================================================
     *
     * PURPOSE
     * -------
     * Tests the OrderItemTrigger for all supported trigger events:
     * - after insert
     * - after update
     * - after delete
     * - bulk insert/update/delete
     *
     * IMPORTANT COVERAGE NOTE
     * -----------------------
     * The current trigger contains:
     *
     *     if (Test.isRunningTest()) {
     *         return;
     *     }
     *
     * Because of that, tests will execute the trigger but will not execute the
     * CustomerOrderLineService.run(...) line. To cover the service-call line,
     * remove the trigger-level Test.isRunningTest() bypass and rely on
     * CustomerOrderLineService.skipAsync instead.
     *
     * TEST DATA
     * ---------
     * Uses CPQ_TestDataFactory.createOrderWithItem(), which creates:
     * Account → Product → PricebookEntry → Order → OrderItem.
     *
     * The bulk test reuses the same Order and PricebookEntry to avoid duplicate
     * setup issues and validation problems.
     * ============================================================================
     */

    @IsTest
    static void testAfterInsert() {
        Test.startTest();

        CPQ_TestDataFactory.OrderBundle bundle =
            CPQ_TestDataFactory.createOrderWithItem();

        Test.stopTest();

        System.assertNotEquals(
            null,
            bundle.orderItem.Id,
            'OrderItem should be inserted successfully.'
        );
    }

    @IsTest
    static void testAfterUpdate() {
        CPQ_TestDataFactory.OrderBundle bundle =
            CPQ_TestDataFactory.createOrderWithItem();

        OrderItem oi = bundle.orderItem;
        oi.Quantity = 5;

        Test.startTest();
        update oi;
        Test.stopTest();

        OrderItem updatedOi = [
            SELECT Id, Quantity
            FROM OrderItem
            WHERE Id = :oi.Id
        ];

        System.assertEquals(
            5,
            updatedOi.Quantity,
            'OrderItem quantity should be updated successfully.'
        );
    }

    @IsTest
    static void testAfterDelete() {
        CPQ_TestDataFactory.OrderBundle bundle =
            CPQ_TestDataFactory.createOrderWithItem();

        OrderItem oi = bundle.orderItem;

        Test.startTest();
        delete oi;
        Test.stopTest();

        Integer remainingCount = [
            SELECT COUNT()
            FROM OrderItem
            WHERE Id = :oi.Id
        ];

        System.assertEquals(
            0,
            remainingCount,
            'OrderItem should be deleted successfully.'
        );
    }

    @IsTest
    static void testBulkInsertUpdateDelete() {
        CPQ_TestDataFactory.OrderBundle bundle =
            CPQ_TestDataFactory.createOrderWithItem();

        List<OrderItem> items = new List<OrderItem>();

        for (Integer i = 0; i < 5; i++) {
            items.add(new OrderItem(
                OrderId                         = bundle.orderRec.Id,
                PricebookEntryId                = bundle.pbe.Id,
                Quantity                        = 1,
                UnitPrice                       = 100,
                ServiceDate                     = Date.today(),
                EndDate                         = Date.today().addMonths(12),
                blng__RevenueRecognitionRule__c = CPQ_TestDataFactory.getRevRecRule().Id,
                blng__BillingRule__c            = CPQ_TestDataFactory.getBillingRule().Id,
                blng__TaxRule__c                = CPQ_TestDataFactory.getTaxRule().Id
            ));
        }

        Test.startTest();

        insert items;

        for (OrderItem oi : items) {
            oi.Quantity = 10;
        }

        update items;
        delete items;

        Test.stopTest();

        System.assertEquals(
            0,
            [
                SELECT COUNT()
                FROM OrderItem
                WHERE Id IN :items
            ],
            'Bulk OrderItems should be deleted successfully.'
        );
    }
}
