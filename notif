/**
 * NotificationService
 * -------------------
 * PURPOSE: When a batch of records is saved to Salesforce and some of them fail,
 * this class sends an email to the person who ran the operation so they know
 * something went wrong. If everything succeeded, no email is sent.
 *
 * NOTES:
 * - Sending emails counts against Salesforce's daily email limits.
 * - In test runs, real emails are never sent, but the invocation is still counted.
 *
 * CHANGES FROM ORIGINAL:
 * - No changes to this class itself. The bugs were only in the test file (see below).
 */
public with sharing class NotificationService {

    public static void handleResults(String subject, Integer totalAttempted, Database.SaveResult[] results){
        Integer failCount = 0;

        if (results == null || results.isEmpty()) return;

        for(Database.SaveResult sr : results){
            if(sr == null || !sr.isSuccess()){ failCount++; }
        }

        if(failCount == 0){ return; }

        Messaging.SingleEmailMessage mail = new Messaging.SingleEmailMessage();
        mail.setToAddresses(new String[] { UserInfo.getUserEmail() });
        mail.setSubject(subject);

        String body = 'One or more records failed during the operation.\n\n' +
            'Total attempted: ' + totalAttempted + '\n' +
            'Failed: ' + failCount + '\n' +
            'Successful: ' + (totalAttempted - failCount);

        mail.setPlainTextBody(body);
        Messaging.sendEmail(new Messaging.SingleEmailMessage[]{ mail });
    }
}

