public class CustomerOrderLineBatch implements Database.Batchable<SObject>, Database.Stateful {

    @TestVisible private Integer insertSuccess = 0;
    @TestVisible private Integer insertFail    = 0;
    @TestVisible private Integer updateSuccess = 0;
    @TestVisible private Integer updateFail    = 0;
    @TestVisible private Integer orphanSuccess = 0;
    @TestVisible private Integer orphanFail    = 0;

    public Database.QueryLocator start(Database.BatchableContext bc) {
        return Database.getQueryLocator(
            'SELECT Id, OrderItemNumber, Product2.Name, ' +
            '       Order.AccountId, SBQQ__Contract__c, SBQQ__Contract__r.Status, ' +
            '       Quantity, TotalPrice, ServiceDate, EndDate, ' +
            '       blng__LastChargeToDate__c, blng__NextBillingDate__c, ' +
            '       SBQQ__DefaultSubscriptionTerm__c ' +
            'FROM   OrderItem ' +
            'WHERE  Id NOT IN (SELECT OrderItem__c FROM CustomerOrderLine__c)'
        );
    }

    public void execute(Database.BatchableContext bc, List<OrderItem> scope) {
        // ── Insert missing COLs ──────────────────────────────────────────────
        List<CustomerOrderLine__c> toInsert = new List<CustomerOrderLine__c>();
        for (OrderItem o : scope) {
            toInsert.add(CustomerOrderLineService.buildCOL(o));
        }

        if (!toInsert.isEmpty()) {
            Database.SaveResult[] insertResults = Database.insert(toInsert, false);
            NotificationService.handleResults(
                'Batch COL Insert', toInsert.size(), insertResults
            );
            for (Database.SaveResult sr : insertResults) {
                if (sr.isSuccess()) { insertSuccess++; } else { insertFail++; }
            }
        }

        // ── Update drifted COLs ──────────────────────────────────────────────
        Set<Id> scopeIds = new Map<Id, OrderItem>(scope).keySet();
        Map<Id, CustomerOrderLine__c> existingCOLs =
            CustomerOrderLineRepository.getByOrderItemIds(scopeIds);

        List<CustomerOrderLine__c> toUpdate = new List<CustomerOrderLine__c>();
        for (OrderItem o : scope) {
            if (!existingCOLs.containsKey(o.Id)) continue;
            CustomerOrderLine__c col = existingCOLs.get(o.Id);

            OrderItem pseudoOld = CustomerOrderLineService.buildPseudoOld(col);
            Boolean changed = CustomerOrderLineService.applyChanges(col, pseudoOld, o);
            if (changed) {
                col.Last_Synced_Date__c = System.now();
                toUpdate.add(col);
            }
        }

        if (!toUpdate.isEmpty()) {
            Database.SaveResult[] updateResults = Database.update(toUpdate, false);
            NotificationService.handleResults(
                'Batch COL Update', toUpdate.size(), updateResults
            );
            for (Database.SaveResult sr : updateResults) {
                if (sr.isSuccess()) { updateSuccess++; } else { updateFail++; }
            }
        }

        // ── Orphan cleanup REMOVED from execute() ────────────────────────────
        // Moved to finish() so it runs exactly once per batch run, not per chunk.
    }

    public void finish(Database.BatchableContext bc) {
        // ── Orphan cleanup (runs once, not per chunk) ────────────────────────
        List<CustomerOrderLine__c> orphans = CustomerOrderLineRepository.getOrphaned();
        List<CustomerOrderLine__c> toTag   = new List<CustomerOrderLine__c>();
        for (CustomerOrderLine__c col : orphans) {
            col.Name                = CustomerOrderLinesUtils.prependDeletedTag(col.Name);
            col.Last_Synced_Date__c = System.now();
            toTag.add(col);
        }

        if (!toTag.isEmpty()) {
            Database.SaveResult[] orphanResults = Database.update(toTag, false);
            NotificationService.handleResults(
                'Batch COL Orphan Cleanup', toTag.size(), orphanResults
            );
            for (Database.SaveResult sr : orphanResults) {
                if (sr.isSuccess()) { orphanSuccess++; } else { orphanFail++; }
            }
        }

        // ── Summary email ────────────────────────────────────────────────────
        AsyncApexJob job = [
            SELECT Id, Status, NumberOfErrors, JobItemsProcessed, TotalJobItems
            FROM   AsyncApexJob
            WHERE  Id = :bc.getJobId()
            LIMIT  1
        ];

        String body =
            'Nightly Customer Order Line Batch Completed.\n\n' +
            'Status           : ' + job.Status             + '\n' +
            'Total Chunks     : ' + job.TotalJobItems      + '\n' +
            'Chunks Processed : ' + job.JobItemsProcessed  + '\n' +
            'Apex Errors      : ' + job.NumberOfErrors     + '\n\n' +
            '── Inserts ──\n' +
            '  Succeeded : ' + insertSuccess + '\n' +
            '  Failed    : ' + insertFail    + '\n\n' +
            '── Updates (drift) ──\n' +
            '  Succeeded : ' + updateSuccess + '\n' +
            '  Failed    : ' + updateFail    + '\n\n' +
            '── Orphan Cleanup ──\n' +
            '  Succeeded : ' + orphanSuccess + '\n' +
            '  Failed    : ' + orphanFail    + '\n\n' +
            'Batch Job Id : ' + job.Id;

        NotificationService.sendSummaryEmail(
            'Nightly Customer Order Line Sync — ' + job.Status,
            body
        );
    }
}
