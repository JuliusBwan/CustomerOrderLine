// ─── NotificationService ─────────────────────────────────────────────────────
/**
 * Central email notification service.
 *
 * Two entry points:
 *  - handleResults()     : called after every DML block; emails only on failure.
 *  - sendSummaryEmail()  : called by the batch finish() to send the nightly summary
 *                          regardless of success/failure.
 *
 * Email addresses are stored as constants here — one place to update them.
 * Production teams should move these to a Custom Metadata Type so they can be
 * changed without a deployment.
 */
public class NotificationService {

    @TestVisible private static final String FAILURE_RECIPIENT = 'julius.bwanika@gbg.com';
    @TestVisible private static final String SUMMARY_RECIPIENT = 'salesforce.admin@gbgplc.com';

    // ── DML RESULT HANDLER ────────────────────────────────────────────────────

    /**
     * Inspects SaveResult[] and sends a failure email when any record failed.
     * Silent on full success — no noise in a healthy org.
     */
    public static void handleResults(
        String operationLabel,
        Integer attemptedCount,
        Database.SaveResult[] results
    ) {
        Integer successCount       = 0;
        Integer failureCount       = 0;
        List<String> failureLines  = new List<String>();

        for (Integer i = 0; i < results.size(); i++) {
            Database.SaveResult sr = results[i];
            if (sr.isSuccess()) {
                successCount++;
            } else {
                failureCount++;
                List<String> errorParts = new List<String>();
                for (Database.Error e : sr.getErrors()) {
                    errorParts.add(
                        'Status: '   + e.getStatusCode() +
                        ' | Field(s): ' + String.join(e.getFields(), ', ') +
                        ' | Message: '  + e.getMessage()
                    );
                }
                // sr.getId() is null on failure — index is the only stable reference
                failureLines.add('Record #' + (i + 1) + ':\n  ' + String.join(errorParts, '\n  '));
            }
        }

        if (failureCount == 0) return; // nothing to report

        String subject =
            operationLabel + ' — ' + failureCount + ' failure(s)';
        String body =
            'Operation : ' + operationLabel  + '\n' +
            'Attempted : ' + attemptedCount  + '\n' +
            'Succeeded : ' + successCount    + '\n' +
            'Failed    : ' + failureCount    + '\n\n' +
            '=== Failure Detail ===\n' +
            String.join(failureLines, '\n\n');

        sendEmail(FAILURE_RECIPIENT, subject, body);
    }

    // ── BATCH SUMMARY ─────────────────────────────────────────────────────────

    /**
     * Sends a plain-text summary email to the admin.
     * Called from CustomerOrderLineBatch.finish() — always fires, win or lose.
     */
    public static void sendSummaryEmail(String subject, String body) {
        sendEmail(SUMMARY_RECIPIENT, subject, body);
    }

    // ── PRIVATE HELPER ────────────────────────────────────────────────────────

    private static void sendEmail(String recipient, String subject, String body) {
        Messaging.SingleEmailMessage mail = new Messaging.SingleEmailMessage();
        mail.setToAddresses(new List<String>{ recipient });
        mail.setSubject(subject);
        mail.setPlainTextBody(body);
        Messaging.sendEmail(new List<Messaging.SingleEmailMessage>{ mail });
    }
}
